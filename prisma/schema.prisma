generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String          @id @default(uuid())
  name           String
  logo           String?
  users          User[]
  shops          Shop[]
  products       Product[]
  sales          Sale[]
  suppliers      Supplier[]
  customers      Customer[]
  createdAt      DateTime        @default(now())
  inventories    Inventory[]
  stockMovements StockMovement[]
  subscriptions Subscription?
  categories     Category[]
  purchases      Purchase[]
}

model User {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name     String
  email    String
  password String
  role     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  userShops      UserShop[]
  stockMovements StockMovement[]
  sales          Sale[]
  purchases      Purchase[]

  @@unique([email])
  @@index([tenantId])
}

model Shop {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name     String
  location String?

  products Product[]
  sales    Sale[]

  userShops UserShop[]
  purchases Purchase[]

  @@index([tenantId])
}

model UserShop {
  id     String @id @default(uuid())
  userId String
  shopId String

  user User @relation(fields: [userId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([userId, shopId])
  @@index([shopId])
}

model Category {
  id       String @id @default(uuid())
  tenantId String
  name     String

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  createdAt DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Supplier {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  name     String
  contact  String?

  products  Product[]
  purchases Purchase[]
}

model Product {
  id         String  @id @default(uuid())
  tenantId   String
  shopId     String
  supplierId String?

  name         String
  sku          String
  categoryId   String?
  costPrice    Float
  sellingPrice Float
  quantity     Int     @default(0)
  minimumStock Int

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  shop     Shop      @relation(fields: [shopId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  category Category? @relation(fields: [categoryId], references:[id])

  inventory      Inventory?
  saleItems      SaleItem[]
  createdAt      DateTime        @default(now())
  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]

  @@index([tenantId, sku])
  @@index([shopId])
}

model Purchase {
  id         String @id @default(uuid())
  tenantId   String
  shopId     String
  supplierId String
  createdBy  String

  totalAmount Float

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  shop     Shop     @relation(fields: [shopId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  creator  User     @relation(fields: [createdBy], references: [id])

  items PurchaseItem[]

  createdAt DateTime @default(now())

  @@index([tenantId, shopId])
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  productId  String

  quantity Int
  cost     Float

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
}

model Inventory {
  id         String   @id @default(uuid())
  tenantId   String
  productId  String   @unique
  currentQty Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([productId])
}

model StockMovement {
  id        String            @id @default(uuid())
  tenantId  String
  productId String
  userId    String
  type      StockMovementType
  quantity  Int
  note      String?
  createdAt DateTime          @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([tenantId, productId])
  @@index([productId, createdAt])
}

enum StockMovementType {
  IN
  OUT
}

model Customer {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name          String
  email         String?
  phone         String?
  address       String?
  loyaltyPoints Int     @default(0)

  sales     Sale[]
  createdAt DateTime @default(now())
}

model Sale {
  id         String  @id @default(uuid())
  tenantId   String
  shopId     String
  customerId String?
  cashierId  String

  totalAmount Float
  paymentType String
  discount    Float?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  shop     Shop      @relation(fields: [shopId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  cashier   User       @relation(fields: [cashierId], references: [id])
  items     SaleItem[]
  createdAt DateTime   @default(now())

  @@index([tenantId, shopId])
  @@index([tenantId, shopId, createdAt])
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  productId String

  quantity Int
  price    Float

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Subscription {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  paystackCustomerId String?
  paystackSubCode    String?
  paystackEmailToken String?

  status            String   // trialing, active, canceled
  plan              String   // monthly / yearly
  currentPeriodEnd  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
